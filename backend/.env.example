# TrendAI Environment Variables
# Copy this file to .env and fill in your actual keys
# NEVER commit .env to git — only commit .env.example

# ======================
# MongoDB
# ======================
MONGODB_URL=mongodb://localhost:27017/ai_project_db
# Or Atlas: mongodb+srv://user:pass@cluster.mongodb.net/ai_project_db

# ======================
# JWT Authentication
# ======================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_secret_key_here

# ======================
# Google Gemini API
# ======================
# Sign up at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_gemini_api_key_here

# ======================
# News API (for trending data)
# ======================
# Sign up at: https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# Fallback News API (used automatically when NewsAPI exhausts)
# Sign up at: https://gnews.io
GNEWS_API_KEY=your_gnews_api_key_here

# ======================
# Razorpay Billing
# ======================
# Sign up at: https://dashboard.razorpay.com
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ======================
# LLM Configuration
# ======================

# LLM Provider: openai, huggingface, ollama, groq
# RECOMMENDED FOR FREE: Use "groq" (6000 tokens/min FREE!)
LLM_PROVIDER=groq

# Groq Configuration (FREE, super fast!)
# Sign up at: https://console.groq.com
# Used for: RAG queries, Product Insights generation, LLM responses
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI Configuration (if using OpenAI - paid but good)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# General LLM Settings
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=500

# ======================
# Embeddings Configuration
# ======================

# Embedding Provider: openai, huggingface
EMBEDDING_PROVIDER=huggingface

# HuggingFace Model (free, runs locally)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# OR use OpenAI embeddings (requires API key)
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-ada-002
# EMBEDDING_DIMENSION=1536

# ======================
# Vector Store Configuration
# ======================

# Vector Store: chromadb, pinecone, faiss
VECTOR_STORE=chromadb

# ChromaDB (Local - Free) - Recommended for development
# Path is relative to backend/ working directory; ../data/chromadb resolves to project root data/
CHROMA_PERSIST_DIR=../data/chromadb
CHROMA_COLLECTION_NAME=market_trends

# Pinecone (Cloud - Requires API key)
# PINECONE_API_KEY=your_pinecone_api_key_here
# PINECONE_ENVIRONMENT=us-east-1
# PINECONE_INDEX_NAME=market-trends-index

# FAISS (Local - Free)
# FAISS_INDEX_PATH=./data/faiss_index

# ======================
# RAG Configuration
# ======================

# Document chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_CHUNKS_PER_DOC=10

# Retrieval settings
RETRIEVAL_TOP_K=5
SIMILARITY_THRESHOLD=0.7
MAX_CONTEXT_LENGTH=3000

# ======================
# Live Chat Configuration
# ======================

# Live Chat Provider: groq (separate Groq API for chat)
LIVE_CHAT_PROVIDER=groq

# ============================================
# Groq Live Chat API (Separate Instance)
# ============================================
# Dedicated Groq API key & model for real-time live chat
# Get your Groq API key from: https://console.groq.com
GROQ_CHAT_ENABLED=true
GROQ_CHAT_API_KEY=your_separate_groq_api_key_here
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_CHAT_TEMPERATURE=0.8
GROQ_CHAT_MAX_TOKENS=1500
GROQ_CHAT_TIMEOUT=30

# ============================================
# General Chat Settings
# ============================================
# Enable/disable live chat feature globally
CHAT_ENABLED=true
# Maximum concurrent chat connections
MAX_CHAT_CONNECTIONS=1000
# Maximum messages per chat session
CHAT_MESSAGE_LIMIT=100
# Session timeout in minutes
CHAT_TIMEOUT_MINUTES=30
# Number of previous messages to keep in context
CHAT_CONTEXT_SIZE=10
# Enable persistent chat history
ENABLE_CHAT_HISTORY=true
# Delay before sending response (ms)
CHAT_RESPONSE_DELAY=500

# ======================
# Email Configuration
# ======================

# Gmail SMTP Settings for OTP & Password Reset
# Step 1: Go to https://myaccount.google.com/security
# Step 2: Enable "2-Step Verification" if not already enabled
# Step 3: Go to https://myaccount.google.com/apppasswords
# Step 4: Select "Mail" and "Windows Computer" (or your device)
# Step 5: Google will generate a 16-character app password
# Step 6: Copy that password below (do NOT use your regular Gmail password)

GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password-here
